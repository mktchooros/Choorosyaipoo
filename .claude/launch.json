{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "sorkroom",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "sorkroom-static",
      "runtimeExecutable": "powershell",
      "runtimeArgs": ["-NoProfile", "-ExecutionPolicy", "Bypass", "-File", "server.ps1"],
      "port": 8000,
      "autoPort": true
    }
  ]
}
